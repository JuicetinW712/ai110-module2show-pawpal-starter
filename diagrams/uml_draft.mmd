classDiagram
  class Owner {
    +String id
    +String name
    +String email
  }
  class Pet {
    +String id
    +String name
    +String species
    +String breed
    +Float weight
  }
  class Scheduler {
    +createTask(petId, task)
    +updateTask(petId, id, task)
    +deleteTask(petId, id)
    +getTasksForDate(petId, date) Task[]
    +getAllTasks(petId) Task[]
  }
  class Task {
    +String id
    +String name
    +String description
    +Int duration
    +String priority
    +Date startDate
    +Date endDate
    +String[] recurringDays
  }
  class Recommendation {
    +String id
    +String petId
    +String category
    +String text
    +String explanation
    +generate(pet, tasks) Rec[]
  }

  Owner *-- "1..*" Pet : owns
  Pet --> Scheduler : schedules for
  Scheduler o-- "0..*" Task : contains
  Pet ..> Recommendation : feeds into
  Scheduler ..> Recommendation : feeds into
