classDiagram
  class Pet {
    +String name
    +String species
    +String breed
    +Int age
    +Float weight
    +updateWeight(w Float)
  }

  class Task {
    +String id
    +String name
    +Int duration
    +String priority
    +String scheduledDate
    +String[] recurringDays
    +isRecurring() Bool
  }

  class DietEntry {
    +String date
    +String mealName
    +Int calories
  }

  class Scheduler {
    +Task[] tasks
    +String petId
    +String date
    +Int availableMinutes
    +createTask(task Task)
    +deleteTask(id String)
    +getTasksForDate(date String)
  }

  class DietTracker {
    +String petId
    +DietEntry[] entries
    +Int dailyCalGoal
    +getCalories(date String)
    +getNutritionLog()
  }

  class Recommendations {
    +Pet pet
    +Scheduler scheduler
    +DietTracker dietTracker
    +generateRecs()
    +explainRec(id String)
  }

  Pet --> Scheduler : schedules for
  Pet --> DietTracker : tracks diet
  Task "0..*" --o Scheduler : contained in
  DietEntry "0..*" --o DietTracker : logged in
  Scheduler ..> Recommendations : feeds into
  DietTracker --> Recommendations : feeds into
  Pet ..> Recommendations : feeds into
